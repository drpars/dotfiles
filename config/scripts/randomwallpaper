#!/bin/bash

# --- Ayarlar ---
DIR=$(xdg-user-dir PICTURES)/Wallpaper
MONITOR="DP-1"
# ----------------

# Desteklenen dosya türleri
find "${DIR}" -type f \( -name "*.jpg" -o -name "*.jpeg" -o -name "*.png" \) -print0 > /tmp/wallpapers.list 2>/dev/null

# Rastgele seçim
RANDOMPICS=$(shuf -n1 < <(find "${DIR}" -type f \( -iname "*.jpg" -o -iname "*.jpeg" -o -iname "*.png" \)))

if [[ -z "$RANDOMPICS" ]]; then
  notify-send -u critical "Random Wallpaper" "Duvar kağıdı bulunamadı!\n$DIR"
  exit 1
fi

# Hyprpaper kontrolü
if pgrep -x "hyprpaper" >/dev/null; then
  hyprctl hyprpaper unload all
  hyprctl hyprpaper preload "$RANDOMPICS"
  hyprctl hyprpaper wallpaper "$MONITOR,$RANDOMPICS"
  
# awww kontrolü
elif pgrep -x "awww-daemon" >/dev/null; then
  pkill swaybg 2>/dev/null
  awww img "$RANDOMPICS" --transition-fps 60 --transition-type any --transition-duration 2
  
else
  # Hiçbiri yoksa awww başlat
  awww-daemon &
  sleep 0.5
  awww img "$RANDOMPICS" --transition-fps 60 --transition-type any --transition-duration 2
fi

# Bildirim (isteğe bağlı)
notify-send -t 2000 "Duvar Kağıdı Değişti" "$(basename "$RANDOMPICS")"
